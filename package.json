{
  "name": "paper-reviewer",
  "version": "0.2.0",
  "description": "Installable PDF manuscript reviewer with linked notes and exported summaries.",
  "author": "Paper Reviewer",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "package:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.paperreviewer.app",
    "productName": "Paper Reviewer",
    "publish": null,
    "files": [
      "electron/**/*",
      "src/**/*",
      "build/icon.png",
      "build/icon.icns",
      "package.json"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ]
    }
  },
  "dependencies": {
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3"
  }
}
